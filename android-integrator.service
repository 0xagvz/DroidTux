[Unit]
Description=DroidTux - Integrador de Aplicaciones Android
Documentation=https://github.com/nexu-io
After=graphical-session.target

[Service]
Type=simple
# Se elimina RemainAfterExit para que el servicio se considere detenido al cerrar la ventana o desconectar
ExecStart=%h/.local/share/droidtux/venv/bin/python3 %h/.local/bin/app_integrator.py --add
ExecStop=%h/.local/share/droidtux/venv/bin/python3 %h/.local/bin/app_integrator.py --remove

[Install]
WantedBy=default.target
